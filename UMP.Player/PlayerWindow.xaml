<Window x:Class="UMP.Player.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        WindowStyle="None" ResizeMode="NoResize"
        Background="Black" Topmost="True"
        PreviewKeyDown="Window_KeyDown">
    <Grid>
        <vlc:VideoView x:Name="VideoView" Background="Black">
            <Grid Background="#01000000">
                <Border x:Name="ImageOverlay" Background="Black"
                        Visibility="Collapsed" IsHitTestVisible="False">
                    <Image x:Name="SlideImage" Stretch="Uniform" IsHitTestVisible="False"/>
                </Border>
                <Canvas x:Name="OverlayCanvas" Background="#01000000"/>
            </Grid>
        </vlc:VideoView>
    </Grid>
</Window>
