<UserControl x:Class="UMP.App.Controls.SubtitlePropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UMP.App.Controls"
             Width="380" Background="{StaticResource BgPanelBrush}">
    <UserControl.Resources>
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A2A"
                        BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="#999999"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   Focusable="False" AllowsTransparency="True">
                                <Border Background="#2A2A2A" BorderBrush="#4A4A4A"
                                        BorderThickness="1" CornerRadius="3" MaxHeight="200">
                                    <ScrollViewer><StackPanel IsItemsHost="True"/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0EA5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <TextBlock Text="SOUS-TITRE" Foreground="White" FontSize="13"
                           FontWeight="SemiBold" FontFamily="{StaticResource UIFont}"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource BtnClose}" Click="BtnCloseProps_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- FICHIER -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="FICHIER" Style="{StaticResource SectionTitle}"/>
                        <DockPanel>
                            <Button Content="..." DockPanel.Dock="Right"
                                    Width="36" Height="30" Margin="6,0,0,0"
                                    Background="{StaticResource BgControlBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnBrowseSrt_Click"/>
                            <TextBox x:Name="TxtFilePath" Style="{StaticResource Input}"
                                     FontSize="9" IsReadOnly="True"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtEntryCount" Text="" Foreground="#78B48C"
                                   FontSize="9" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- APPARENCE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="APPARENCE" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fond" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BgPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BgColor_Click"/>
                                    <TextBox x:Name="TxtBg" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBg_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Texte" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="FgPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="FgColor_Click"/>
                                    <TextBox x:Name="TxtFg" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtFg_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Opacite (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtOpacity" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Padding (px)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtPadding" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <!-- Bordure -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bord (px)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtBorderWidth" Style="{StaticResource Input}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BorderPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BorderColor_Click"/>
                                    <TextBox x:Name="TxtBorderColor" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBorderColor_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Arrondi (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtCorner" Style="{StaticResource Input}" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <!-- Alignement -->
                        <TextBlock Text="Alignement" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbAlignLeft" Grid.Column="0" Checked="Align_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="28" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand" BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="Gauche" Foreground="White" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbAlignCenter" Grid.Column="2" IsChecked="True" Checked="Align_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="28" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand" BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="Centre" Foreground="White" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbAlignRight" Grid.Column="4" Checked="Align_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="28" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand" BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="Droite" Foreground="White" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- TYPOGRAPHIE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="TYPOGRAPHIE" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Police" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbFontFamily" Margin="0,0,0,4"
                                  Style="{StaticResource DarkCombo}"
                                  ItemContainerStyle="{StaticResource DarkComboItem}"/>
                        <DockPanel Margin="0,0,0,8">
                            <Button Content="X" DockPanel.Dock="Right"
                                    Width="28" Height="24" Margin="4,0,0,0"
                                    Background="#3A2020" Foreground="#E05050"
                                    BorderThickness="0" Cursor="Hand" FontSize="10"
                                    ToolTip="Retirer la police personnalisee"
                                    Click="BtnRemoveCustomFont_Click"
                                    x:Name="BtnRemoveCustomFont" Visibility="Collapsed"/>
                            <Button Content="Importer une police (.ttf / .otf)"
                                    Height="24"
                                    Background="{StaticResource BgControlBrush}" Foreground="#AAAACC"
                                    BorderThickness="1" BorderBrush="{StaticResource BgBorderBrush}"
                                    Cursor="Hand" FontSize="10"
                                    Click="BtnImportFont_Click"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtCustomFontInfo" Text="" Foreground="#78B48C"
                                   FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Graisse" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbFontWeight"
                                          Style="{StaticResource DarkCombo}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Taille (pt)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtFontSize" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- OMBRAGE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="OMBRAGE" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Flou (px)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtShadowBlur" Style="{StaticResource Input}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="ShadowPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="ShadowColor_Click"/>
                                    <TextBox x:Name="TxtShadowColor" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtShadowColor_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Decalage X" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtShadowX" Style="{StaticResource Input}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Decalage Y" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtShadowY" Style="{StaticResource Input}" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CONTOUR -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="CONTOUR" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Epaisseur" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtOutlineWidth" Style="{StaticResource Input}" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="OutlinePreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="OutlineColor_Click"/>
                                    <TextBox x:Name="TxtOutlineColor" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtOutlineColor_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- POSITION -->
                <Border Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="POSITION" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtX" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtY" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Largeur (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtW" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Appliquer" Height="32" Padding="20,0"
                                Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"
                                FontSize="11" BorderThickness="0" Cursor="Hand"
                                Margin="0,12,0,4" HorizontalAlignment="Stretch"
                                Click="BtnApply_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <controls:ColorPickerPanel x:Name="ColorPicker" Grid.RowSpan="2"
                                    Visibility="Collapsed"/>
    </Grid>
</UserControl>
