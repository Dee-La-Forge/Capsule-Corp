<UserControl x:Class="UMP.App.Controls.ButtonPropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="380" Background="{StaticResource BgPanelBrush}">
    <UserControl.Resources>
        <!-- Toggle button for ComboBox dropdown arrow -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A2A"
                        BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="#999999"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   Focusable="False" AllowsTransparency="True">
                                <Border Background="#2A2A2A" BorderBrush="#4A4A4A"
                                        BorderThickness="1" CornerRadius="3"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0EA5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER — meme style que SequencePanel -->
        <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <TextBlock Text="PROPRIETES" Foreground="White" FontSize="13"
                           FontWeight="SemiBold" FontFamily="{StaticResource UIFont}"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource BtnClose}" Click="BtnCloseProps_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 1. TYPE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="TYPE" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbSimple" Grid.Column="0"
                                         IsChecked="True" Checked="RbType_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="32" CornerRadius="6"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="Simple" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbToggle" Grid.Column="2"
                                         Checked="RbType_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="32" CornerRadius="6"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="Toggle (ON/OFF)" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. APPARENCE (OFF) -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock x:Name="LblStyle" Text="APPARENCE"
                                   Style="{StaticResource SectionTitle}"/>
                        <!-- Label -->
                        <TextBlock Text="Label" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtLabel" Style="{StaticResource Input}"
                                 Margin="0,0,0,10" TextChanged="TxtLabel_Changed"/>
                        <!-- Fond + Texte -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fond" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BgPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BgColor_Click"/>
                                    <TextBox x:Name="TxtBg" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBg_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Texte" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="FgPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="FgColor_Click"/>
                                    <TextBox x:Name="TxtFg" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtFg_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                        <!-- Image -->
                        <TextBlock Text="Image" Style="{StaticResource FieldLabel}" Margin="0,6,0,4"/>
                        <DockPanel>
                            <Button Content="..." DockPanel.Dock="Right"
                                    Width="36" Height="30" Margin="6,0,0,0"
                                    Background="{StaticResource BgControlBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnBrowseImage_Click"/>
                            <Button Content="X" DockPanel.Dock="Right"
                                    Width="28" Height="30" Margin="4,0,0,0"
                                    Background="#3C1E1E" Foreground="#F88"
                                    BorderThickness="0" Cursor="Hand" FontSize="10"
                                    Click="BtnClearImage_Click"/>
                            <TextBox x:Name="TxtImgPath" Style="{StaticResource Input}"
                                     FontSize="9" IsReadOnly="True"/>
                        </DockPanel>
                        <Border x:Name="ImgPreview" Height="60" Margin="0,6,0,0"
                                Background="{StaticResource BgInputBrush}" CornerRadius="4"
                                Visibility="Collapsed">
                            <Image x:Name="ImgPreviewImg" Stretch="Uniform"/>
                        </Border>
                        <!-- Bordure -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bord (px)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtBorderWidth" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BorderColorPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BorderColor_Click"/>
                                    <TextBox x:Name="TxtBorderColor" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBorderColor_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <RadioButton x:Name="RbBorderIn" Grid.Column="4"
                                         IsChecked="True" Checked="BorderPos_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="30" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                                                Margin="0,18,0,0">
                                            <TextBlock Text="Int." Foreground="White"
                                                       FontSize="9" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbBorderOut" Grid.Column="6"
                                         Checked="BorderPos_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="30" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                                                Margin="0,18,0,0">
                                            <TextBlock Text="Ext." Foreground="White"
                                                       FontSize="9" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. TYPOGRAPHIE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="TYPOGRAPHIE" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Police" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbFontFamily" Margin="0,0,0,4"
                                  Style="{StaticResource DarkCombo}"
                                  ItemContainerStyle="{StaticResource DarkComboItem}"/>
                        <DockPanel Margin="0,0,0,4">
                            <Button Content="X" DockPanel.Dock="Right"
                                    Width="28" Height="24" Margin="4,0,0,0"
                                    Background="#3A2020" Foreground="#E05050"
                                    BorderThickness="0" Cursor="Hand" FontSize="10"
                                    ToolTip="Retirer la police personnalisee"
                                    Click="BtnRemoveCustomFont_Click"
                                    x:Name="BtnRemoveCustomFont" Visibility="Collapsed"/>
                            <Button Content="Importer une police (.ttf / .otf)"
                                    Height="24"
                                    Background="{StaticResource BgControlBrush}" Foreground="#AAAACC"
                                    BorderThickness="1" BorderBrush="{StaticResource BgBorderBrush}"
                                    Cursor="Hand" FontSize="10"
                                    Click="BtnImportFont_Click"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtCustomFontInfo" Text="" Foreground="#78B48C"
                                   FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Graisse" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbFontWeight"
                                          Style="{StaticResource DarkCombo}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Taille (pt)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtFontSize" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 4. SURVOL -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="SURVOL" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fond" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BgHoverPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BgHoverColor_Click"/>
                                    <TextBox x:Name="TxtBgHover" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBgHover_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Texte" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="FgHoverPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="FgHoverColor_Click"/>
                                    <TextBox x:Name="TxtFgHover" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtFgHover_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Taille (pt)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtFontSizeHover" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Graisse" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbFontWeightHover"
                                          Style="{StaticResource DarkCombo}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bord" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtBorderWidthHover" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BorderHoverPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BorderHoverColor_Click"/>
                                    <TextBox x:Name="TxtBorderHover" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBorderHover_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <RadioButton x:Name="RbBorderInH" Grid.Column="4"
                                         IsChecked="True" Checked="BorderPos_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="30" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Margin="0,18,0,0">
                                            <TextBlock Text="Int." Foreground="White" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbBorderOutH" Grid.Column="6"
                                         Checked="BorderPos_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="30" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Margin="0,18,0,0">
                                            <TextBlock Text="Ext." Foreground="White" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 5. APPARENCE ON -->
                <Border x:Name="SectionOn" Style="{StaticResource Section}"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="APPARENCE ON" Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="Label ON" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtLabelOn" Style="{StaticResource Input}"
                                 Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fond ON" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BgOnPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BgOnColor_Click"/>
                                    <TextBox x:Name="TxtBgOn" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBgOn_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Texte ON" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="FgOnPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="FgOnColor_Click"/>
                                    <TextBox x:Name="TxtFgOn" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtFgOn_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                        <!-- Image ON -->
                        <TextBlock Text="Image ON" Style="{StaticResource FieldLabel}" Margin="0,6,0,4"/>
                        <DockPanel Margin="0,0,0,6">
                            <Button Content="..." DockPanel.Dock="Right"
                                    Width="36" Height="30" Margin="6,0,0,0"
                                    Background="{StaticResource BgControlBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnBrowseImageOn_Click"/>
                            <Button Content="X" DockPanel.Dock="Right"
                                    Width="28" Height="30" Margin="4,0,0,0"
                                    Background="#3C1E1E" Foreground="#F88"
                                    BorderThickness="0" Cursor="Hand" FontSize="10"
                                    Click="BtnClearImageOn_Click"/>
                            <TextBox x:Name="TxtImgPathOn" Style="{StaticResource Input}"
                                     FontSize="9" IsReadOnly="True"/>
                        </DockPanel>
                        <!-- Taille + Graisse ON -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Taille (pt)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtFontSizeOn" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Graisse" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="CmbFontWeightOn"
                                          Style="{StaticResource DarkCombo}"
                                          ItemContainerStyle="{StaticResource DarkComboItem}"/>
                            </StackPanel>
                        </Grid>
                        <!-- Bordure ON -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bord" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtBorderWidthOn" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BorderOnPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BorderOnColor_Click"/>
                                    <TextBox x:Name="TxtBorderOn" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBorderOn_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <RadioButton x:Name="RbBorderInO" Grid.Column="4"
                                         IsChecked="True" Checked="BorderPos_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="30" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Margin="0,18,0,0">
                                            <TextBlock Text="Int." Foreground="White" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbBorderOutO" Grid.Column="6"
                                         Checked="BorderPos_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="Bd" Height="30" CornerRadius="4"
                                                Background="{StaticResource BgControlBrush}" Cursor="Hand"
                                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Margin="0,18,0,0">
                                            <TextBlock Text="Ext." Foreground="White" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 6. DIMENSIONS -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="DIMENSIONS" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Largeur (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtW" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Hauteur (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtH" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Arrondi (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtCorner" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Padding (px)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtPadding" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Opacite (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtOpacity" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 7. ACTIONS -->
                <Border Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="ACTIONS" Style="{StaticResource SectionTitle}"/>
                        <StackPanel x:Name="TabsActions" Orientation="Horizontal"
                                    Margin="0,0,0,8" Visibility="Collapsed">
                            <Button x:Name="BtnTabOff" Content="Etat OFF" Height="26"
                                    Padding="12,0" Background="{StaticResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Margin="0,0,4,0" Cursor="Hand"
                                    FontSize="10" Click="BtnTabOff_Click"/>
                            <Button x:Name="BtnTabOn" Content="Etat ON" Height="26"
                                    Padding="12,0" Background="{StaticResource BgControlBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    FontSize="10" Click="BtnTabOn_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="ActionsPanel"/>
                        <Button Content="+ Ajouter une action" Height="28"
                                Background="{StaticResource BgInputBrush}" Foreground="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                                Cursor="Hand" Margin="0,8,0,0" FontSize="10"
                                Click="BtnAddAction_Click"/>
                        <Button Content="Appliquer" Height="32" Padding="20,0"
                                Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"
                                FontSize="11" BorderThickness="0" Cursor="Hand"
                                Margin="0,12,0,4" HorizontalAlignment="Stretch"
                                Click="BtnApply_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <!-- Color Picker popup overlay -->
        <controls:ColorPickerPanel x:Name="ColorPicker" Grid.RowSpan="2"
                                    Visibility="Collapsed"
                                    xmlns:controls="clr-namespace:UMP.App.Controls"/>
    </Grid>
</UserControl>
