<UserControl x:Class="UMP.App.Controls.PipPropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:UMP.App.Controls"
             Width="380" Background="{StaticResource BgPanelBrush}">
    <UserControl.Resources>
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A2A"
                        BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="3"/>
                <Path x:Name="Arrow" Grid.Column="1" Fill="#999999"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   Focusable="False" AllowsTransparency="True">
                                <Border Background="#2A2A2A" BorderBrush="#4A4A4A"
                                        BorderThickness="1" CornerRadius="3" MaxHeight="200">
                                    <ScrollViewer><StackPanel IsItemsHost="True"/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0EA5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <TextBlock Text="PICTURE IN PICTURE" Foreground="White" FontSize="13"
                           FontWeight="SemiBold" FontFamily="{StaticResource UIFont}"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource BtnClose}" Click="BtnCloseProps_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- FICHIER -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="FICHIER" Style="{StaticResource SectionTitle}"/>
                        <DockPanel>
                            <Button Content="..." DockPanel.Dock="Right"
                                    Width="36" Height="30" Margin="6,0,0,0"
                                    Background="{StaticResource BgControlBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnBrowseVideo_Click"/>
                            <TextBox x:Name="TxtFilePath" Style="{StaticResource Input}"
                                     FontSize="9" IsReadOnly="True"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- APPARENCE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="APPARENCE" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Opacite (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtOpacity" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Volume (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtVolume" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Arrondi (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtCorner" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Boucle" Style="{StaticResource FieldLabel}"/>
                                <CheckBox x:Name="ChkLoop" Foreground="White" VerticalAlignment="Center"
                                          Height="30" VerticalContentAlignment="Center"
                                          Checked="ChkLoop_Changed" Unchecked="ChkLoop_Changed"/>
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="ChkStartHidden" Content="Demarre cache"
                                  Foreground="White" FontSize="11" Margin="0,6,0,0"
                                  Checked="ChkStartHidden_Changed" Unchecked="ChkStartHidden_Changed"/>
                    </StackPanel>
                </Border>

                <!-- BORDURE -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <TextBlock Text="BORDURE" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Epaisseur (px)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtBorderWidth" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Couleur" Style="{StaticResource FieldLabel}"/>
                                <DockPanel>
                                    <Border x:Name="BorderPreview" DockPanel.Dock="Left"
                                            Width="30" Height="30" CornerRadius="4"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BorderColor_Click"/>
                                    <TextBox x:Name="TxtBorderColor" Style="{StaticResource Input}"
                                             FontSize="10" TextChanged="TxtBorderColor_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DIMENSIONS -->
                <Border Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="DIMENSIONS" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtX" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtY" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Largeur (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtW" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Hauteur (%)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtH" Style="{StaticResource Input}"
                                         FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Appliquer" Height="32" Padding="20,0"
                                Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"
                                FontSize="11" BorderThickness="0" Cursor="Hand"
                                Margin="0,12,0,4" HorizontalAlignment="Stretch"
                                Click="BtnApply_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <controls:ColorPickerPanel x:Name="ColorPicker" Grid.RowSpan="2"
                                    Visibility="Collapsed"/>
    </Grid>
</UserControl>
