<UserControl x:Class="UMP.App.Controls.ZoneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:controls="clr-namespace:UMP.App.Controls"
             Background="Black">
    <UserControl.Resources>
        <!-- Timeline — barre de progression + thumb pro -->
        <Style x:Key="TimelineRepeatBtnLeft" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" CornerRadius="2" Background="{StaticResource AccentBrush}"
                                VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimelineRepeatBtnRight" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="4" CornerRadius="2" Background="#252538"
                                VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimelineThumb" TargetType="Thumb">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <!-- Ombre -->
                            <Ellipse Width="14" Height="14" Fill="{StaticResource BgControlBrush}"
                                     Margin="0,1,0,0"/>
                            <!-- Cercle principal -->
                            <Ellipse x:Name="circle" Width="12" Height="12" Fill="{StaticResource AccentBrush}"
                                     Stroke="{StaticResource AccentLightBrush}" StrokeThickness="1.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Width" Value="14"/>
                                <Setter TargetName="circle" Property="Height" Value="14"/>
                                <Setter TargetName="circle" Property="Fill" Value="{StaticResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="circle" Property="Width" Value="16"/>
                                <Setter TargetName="circle" Property="Height" Value="16"/>
                                <Setter TargetName="circle" Property="Fill" Value="#9B8FFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimelineSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <!-- Track fond (toute la barre) -->
                            <Border Height="4" CornerRadius="2" Background="#252538"
                                    Margin="7,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TimelineRepeatBtnLeft}"
                                                  Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TimelineRepeatBtnRight}"
                                                  Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TimelineThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColBtnProps" Width="0"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="ColSequence" Width="0"/>
        </Grid.ColumnDefinitions>
        <controls:ButtonPropertiesPanel x:Name="BtnPropsPanel" Grid.Column="0"
                                         Visibility="Collapsed"/>
        <controls:SubtitlePropertiesPanel x:Name="SubPropsPanel" Grid.Column="0"
                                          Visibility="Collapsed"/>
        <controls:PipPropertiesPanel x:Name="PipPropsPanel" Grid.Column="0"
                                      Visibility="Collapsed"/>
        <controls:ImagePropertiesPanel x:Name="ImgPropsPanel" Grid.Column="0"
                                        Visibility="Collapsed"/>
        <Grid Grid.Column="1" Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDarkBrush}"
                    BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,0,0,1">
                <TextBox x:Name="TxtZoneName" Background="Transparent"
                         Foreground="White" BorderThickness="0" FontSize="13"
                         FontWeight="SemiBold" FontFamily="{StaticResource UIFont}"
                         VerticalAlignment="Center" Padding="12,0" CaretBrush="White"
                         TextChanged="TxtZoneName_TextChanged"/>
            </Border>

            <Grid Grid.Row="1" Background="Black" ClipToBounds="True"
                  AllowDrop="True" Drop="VideoArea_Drop" DragOver="VideoArea_DragOver"
                  DragEnter="VideoArea_DragEnter" DragLeave="VideoArea_DragLeave">
                <Border x:Name="DropOverlay" Background="#335C4FBF" Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <TextBlock Text="Deposer les fichiers ici" Foreground="White"
                               FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <vlc:VideoView x:Name="VideoView" Background="Black">
                    <Grid Background="#01000000">
                        <Border x:Name="ImageOverlay" Background="Black"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <Image x:Name="SlideImage" Stretch="Uniform"
                                   IsHitTestVisible="False"/>
                        </Border>
                        <Canvas x:Name="OverlayCanvas" Background="#01000000"
                                IsHitTestVisible="True"
                                MouseMove="OverlayCanvas_MouseMove"
                                MouseLeftButtonUp="OverlayCanvas_MouseUp"
                                MouseRightButtonUp="OverlayCanvas_MouseUp"/>
                    </Grid>
                </vlc:VideoView>
            </Grid>

            <!-- TIMELINE -->
            <Border x:Name="TimelineBorder" Grid.Row="2" Background="{StaticResource BgDeepBrush}"
                    BorderBrush="{StaticResource BgWindowBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Graduations -->
                    <Canvas x:Name="TimelineRuler" Grid.Row="0" Height="14"
                            Background="Transparent" ClipToBounds="True"/>
                    <!-- Slider + timecodes -->
                    <Grid Grid.Row="1" Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource BgDarkBrush}" CornerRadius="3"
                                Padding="5,1" Margin="6,3" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtPosition" Text="00:00:00.00"
                                       Foreground="{StaticResource AccentBrush}" FontSize="10"
                                       FontFamily="Consolas" FontWeight="SemiBold"/>
                        </Border>
                        <Grid Grid.Column="1">
                            <Slider x:Name="TimelineSlider"
                                    Minimum="0" Maximum="1000" Value="0"
                                    VerticalAlignment="Center" Margin="2,0"
                                    IsMoveToPointEnabled="True"
                                    Style="{StaticResource TimelineSliderStyle}"
                                    PreviewMouseLeftButtonUp="TimelineSlider_MouseUp"
                                    ValueChanged="TimelineSlider_ValueChanged"/>
                            <!-- Brackets IN/OUT -->
                            <Canvas x:Name="BracketsCanvas" Height="28"
                                    ClipToBounds="False"/>
                        </Grid>
                        <Border Grid.Column="2" Background="{StaticResource BgDarkBrush}" CornerRadius="3"
                                Padding="5,1" Margin="6,3" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtDuration" Text="00:00:00.00"
                                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="10"
                                       FontFamily="Consolas"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource BgBarBrush}"
                    BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,1,0,0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <Button Content="&#128194;" Style="{StaticResource Btn}" Height="32"
                            ToolTip="Ouvrir un fichier"
                            Margin="2,0" Click="BtnOpen_Click"/>
                    <Button x:Name="BtnPlayPause" Content="&#9654;"
                            Style="{StaticResource BtnAccent}" Height="32"
                            ToolTip="Lecture / Pause" FontSize="14"
                            Margin="2,0" Click="BtnPlayPause_Click"/>
                    <Button Content="&#9632;" Style="{StaticResource Btn}" Height="32"
                            ToolTip="Stop" FontSize="14"
                            Margin="2,0" Click="BtnStop_Click"/>
                    <Rectangle Width="1" Fill="{StaticResource BgBorderBrush}" Margin="6,6"/>
                    <ToggleButton x:Name="ChkLoop" Visibility="Collapsed"
                                  Checked="ChkLoop_Checked" Unchecked="ChkLoop_Unchecked"/>
                    <Button x:Name="BtnMute" Content="&#128266;"
                            Style="{StaticResource Btn}" Height="32"
                            ToolTip="Muet" FontSize="13"
                            Width="34" Margin="2,0" Click="BtnMute_Click"/>
                    <Slider x:Name="VolumeSlider" Width="80" Minimum="0" Maximum="100"
                            Value="100" VerticalAlignment="Center" Margin="4,0"
                            Style="{StaticResource TimelineSliderStyle}" Height="18"
                            ValueChanged="VolumeSlider_ValueChanged"/>
                    <TextBlock x:Name="TxtVolume" Text="100" Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="9" VerticalAlignment="Center" Margin="2,0" Width="22"
                               FontFamily="{StaticResource MonoFont}"/>
                    <Rectangle Width="1" Fill="{StaticResource BgBorderBrush}" Margin="6,4"/>
                    <Button x:Name="BtnScreen" Style="{StaticResource Btn}" Height="32"
                            ToolTip="Ecran de sortie" Margin="2,0"
                            Click="BtnScreen_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#128424;" FontSize="13" Margin="0,0,4,0"/>
                            <TextBlock x:Name="TxtScreen" Text="Ecran 1" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{StaticResource BgBorderBrush}" Margin="6,4"/>
                    <Button Content="&#127916; Sequence" Style="{StaticResource Btn}" Height="32"
                            Margin="2,0" Click="BtnSequence_Click"/>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <controls:SequencePanel x:Name="SeqPanel" Grid.Column="2"
                                Visibility="Collapsed"/>
    </Grid>
</UserControl>
