<Window x:Class="UMP.App.Windows.ButtonPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proprietes du bouton" Height="650" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#1E1E2E">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource BgBarBrush}" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" Height="36" Padding="20,0"
                        Background="{StaticResource BgControlBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                        Click="BtnCancel_Click"/>
                <Button Content="Appliquer" Height="36" Padding="20,0"
                        Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnApply_Click"/>
            </StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,16,16,8">

                <!-- HEADER -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border x:Name="PreviewBox" Width="48" Height="48"
                            CornerRadius="8" Margin="0,0,12,0">
                        <TextBlock x:Name="PreviewLabel" Text="Btn"
                                   Foreground="White" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bouton overlay" FontSize="16"
                                   FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Configurer l'apparence et les actions"
                                   FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- TYPE -->
                <Border Background="#2A2A3E" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="TYPE" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbSimple" Content="Simple"
                                         Foreground="White" FontSize="12"
                                         IsChecked="True" Margin="0,0,20,0"
                                         Checked="RbType_Changed"/>
                            <RadioButton x:Name="RbToggle" Content="Toggle (ON/OFF)"
                                         Foreground="White" FontSize="12"
                                         Checked="RbType_Changed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- LABEL + COULEURS -->
                <Border Background="#2A2A3E" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblStyle" Text="APPARENCE" FontSize="9"
                                   FontWeight="Bold" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="Label" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtLabel" Background="{StaticResource BgInputBrush}" Foreground="White"
                                 BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                                 Padding="10,6" Height="34" FontSize="13"
                                 Margin="0,0,0,12" TextChanged="TxtLabel_Changed"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fond" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                <DockPanel>
                                    <Border x:Name="BgPreview" DockPanel.Dock="Left"
                                            Width="34" Height="34" CornerRadius="6"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="BgColor_Click"/>
                                    <TextBox x:Name="TxtBg" Background="{StaticResource BgInputBrush}"
                                             Foreground="White" BorderBrush="{StaticResource BgBorderBrush}"
                                             BorderThickness="1" Padding="8,6" Height="34"
                                             TextChanged="TxtBg_Changed"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Texte" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                <DockPanel>
                                    <Border x:Name="FgPreview" DockPanel.Dock="Left"
                                            Width="34" Height="34" CornerRadius="6"
                                            Margin="0,0,6,0" Cursor="Hand"
                                            MouseLeftButtonUp="FgColor_Click"/>
                                    <TextBox x:Name="TxtFg" Background="{StaticResource BgInputBrush}"
                                             Foreground="White" BorderBrush="{StaticResource BgBorderBrush}"
                                             BorderThickness="1" Padding="8,6" Height="34"
                                             TextChanged="TxtFg_Changed"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- STYLE ON -->
                <Border x:Name="SectionOn" Background="#2A2A3E" CornerRadius="8"
                        Padding="14" Margin="0,0,0,10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="APPARENCE ETAT ON" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="Label ON" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtLabelOn" Background="{StaticResource BgInputBrush}" Foreground="White"
                                 BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                                 Padding="10,6" Height="34" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fond ON" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtBgOn" Background="{StaticResource BgInputBrush}" Foreground="White"
                                         BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Padding="8,6" Height="34"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Texte ON" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtFgOn" Background="{StaticResource BgInputBrush}" Foreground="White"
                                         BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Padding="8,6" Height="34"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DIMENSIONS -->
                <Border Background="#2A2A3E" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="DIMENSIONS" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Largeur (%)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtW" Background="{StaticResource BgInputBrush}" Foreground="White"
                                         BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Padding="8,6" Height="34"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Hauteur (%)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtH" Background="{StaticResource BgInputBrush}" Foreground="White"
                                         BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1" Padding="8,6" Height="34"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ACTIONS -->
                <Border Background="#2A2A3E" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="ACTIONS" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,10"/>
                        <StackPanel x:Name="TabsActions" Orientation="Horizontal"
                                    Margin="0,0,0,8" Visibility="Collapsed">
                            <Button x:Name="BtnTabOff" Content="Etat OFF" Height="28"
                                    Padding="14,0" Background="{StaticResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Margin="0,0,4,0" Cursor="Hand"
                                    Click="BtnTabOff_Click"/>
                            <Button x:Name="BtnTabOn" Content="Etat ON" Height="28"
                                    Padding="14,0" Background="{StaticResource BgControlBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="BtnTabOn_Click"/>
                        </StackPanel>
                        <StackPanel x:Name="ActionsPanel"/>
                        <Button Content="+ Ajouter une action" Height="32"
                                Background="{StaticResource BgInputBrush}" Foreground="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                                Cursor="Hand" Margin="0,8,0,0" FontSize="11"
                                Click="BtnAddAction_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
