<Window x:Class="UMP.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:UMP.App.Controls"
        Title="CapsuleMedia" Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="Black" Closing="Window_Closing"
        Icon="Assets/Pillule.png"
        PreviewKeyDown="Window_KeyDown"
        WindowStyle="None" ResizeMode="CanResizeWithGrip">

    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- BARRE DU HAUT -->
        <Border Grid.Row="0" Background="{StaticResource BgBarBrush}"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#128190; Sauvegarder" Style="{StaticResource Btn}"
                            Click="BtnSave_Click" Margin="0,0,4,0"
                            ToolTip="Sauvegarder sous... (Ctrl+S)"/>
                    <Button Content="&#128194; Ouvrir" Style="{StaticResource Btn}"
                            Click="BtnLoad_Click" Margin="0,0,4,0"
                            ToolTip="Ouvrir un projet (Ctrl+O)"/>
                    <Rectangle Width="1" Fill="{StaticResource TextMutedBrush}" Margin="8,8"/>
                    <Button Content="&#x21A9;" Style="{StaticResource Btn}"
                            Click="BtnUndo_Click" Margin="0,0,2,0" Width="30" Padding="0"
                            ToolTip="Annuler (Ctrl+Z)" FontSize="14"/>
                    <Button Content="&#x21AA;" Style="{StaticResource Btn}"
                            Click="BtnRedo_Click" Margin="0,0,4,0" Width="30" Padding="0"
                            ToolTip="Retablir (Ctrl+Y)" FontSize="14"/>
                    <Rectangle Width="1" Fill="{StaticResource TextMutedBrush}" Margin="8,8"/>
                    <Button Style="{StaticResource BtnAccent}"
                            Click="BtnExport_Click" Padding="12,0" Margin="0,0,4,0"
                            ToolTip="Generer un executable autonome pour la lecture">
                        <TextBlock Text="&#x1F48A; Export" FontSize="12"/>
                    </Button>
                    <Rectangle Width="1" Fill="{StaticResource TextMutedBrush}" Margin="8,8"/>
                    <Button Content="&#9654; Preview" Style="{StaticResource Btn}"
                            Click="BtnPreview_Click" Margin="0,0,4,0"
                            ToolTip="Lancer la lecture en plein ecran sur les ecrans assignes"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Width="36" Height="36" Cursor="Hand" Margin="0,0,12,0"
                            Background="Transparent" PreviewMouseLeftButtonUp="Pillule_Click">
                        <Image Source="Assets/Pillule.png" Stretch="Uniform"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <RotateTransform Angle="-15"/>
                            </Image.RenderTransform>
                        </Image>
                    </Border>
                    <Rectangle Width="1" Fill="{StaticResource BgBorderBrush}" Margin="0,10,0,10"/>
                    <Button Content="&#x2014;" Width="40" Height="30" FontSize="10"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" Click="BtnMinimize_Click"
                            ToolTip="Reduire"/>
                    <Button x:Name="BtnMaxRestore" Content="&#x25A1;" Width="40" Height="30" FontSize="12"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" Click="BtnMaxRestore_Click"
                            ToolTip="Agrandir"/>
                    <Button Content="&#x2715;" Width="40" Height="30" FontSize="10"
                            Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand" Click="BtnCloseWindow_Click"
                            ToolTip="Fermer">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LOADER -->
        <Border x:Name="LoaderOverlay" Grid.RowSpan="3" Background="#CC000000"
                Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/loader.png" Width="164" Height="164"
                       Stretch="Uniform" RenderTransformOrigin="0.7,0.7">
                    <Image.RenderTransform>
                        <RotateTransform x:Name="LoaderRotation" Angle="0"/>
                    </Image.RenderTransform>
                    <Image.Triggers>
                        <EventTrigger RoutedEvent="Image.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="LoaderRotation"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="0" Duration="0:10:0"
                                                     RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Image.Triggers>
                </Image>
                <TextBlock x:Name="LoaderText" Text="Chargement du projet..."
                           Foreground="White" FontSize="13" FontFamily="{StaticResource UIFont}"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <!-- ZONE ACTIVE -->
        <Grid Grid.Row="1" Background="Black">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ColPhysicalBtns" Width="0"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Background="Black">
                <ContentPresenter x:Name="ActiveZonePresenter"/>
                <Border x:Name="PanelNoZone" Background="{StaticResource BgWindowBrush}"
                    Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#127916;" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Aucune zone selectionnee" Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="Cliquez + pour ajouter une zone" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            </Grid>
            <controls:PhysicalButtonsPanel x:Name="PhysicalBtnsPanel"
                                            Grid.Column="1" Visibility="Collapsed"/>
        </Grid>

        <!-- MINIATURES EN BAS -->
        <Border Grid.Row="2" Background="{StaticResource BgBarBrush}"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="ThumbnailStrip" Orientation="Horizontal" Margin="8,6"/>
                    </ScrollViewer>
                    <TextBlock Text="v1.00 — M. Boukheddouma"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="7"
                               FontFamily="{StaticResource UIFont}"
                               HorizontalAlignment="Left" VerticalAlignment="Bottom"
                               Margin="8,0,0,1" IsHitTestVisible="False"/>
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,12,0">
                    <Button Content="&#127918;" Style="{StaticResource Btn}"
                            Width="38" Height="38" FontSize="16" Padding="0"
                            Margin="0,0,6,0" Click="BtnPhysicalButtons_Click"
                            ToolTip="Boutons physiques (clavier, joystick)"/>
                    <Rectangle Width="1" Fill="{StaticResource BgBorderBrush}" Margin="0,8,6,8"/>
                    <Button Content="&#8722;" Style="{StaticResource Btn}"
                            Width="38" Height="38" FontSize="20" Padding="0"
                            Margin="0,0,6,0" Click="BtnRemoveZone_Click"
                            ToolTip="Supprimer la zone"/>
                    <Button Content="+" Style="{StaticResource BtnAccent}"
                            Width="38" Height="38" FontSize="22" Padding="0"
                            Click="BtnAddZone_Click"
                            ToolTip="Ajouter une zone"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
